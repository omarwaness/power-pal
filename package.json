{
  "name": "powerpal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:icon": "node scripts/build-icon.cjs",
    "package:win": "npm run build && npm run build:icon && electron-builder --win portable && node scripts/sync-package-output.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "rebuild:native": "electron-builder install-app-deps",
    "postinstall": "npm run rebuild:native"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.0",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "png-to-ico": "^2.1.8",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  },
  "build": {
    "directories": {
      "output": "release-build"
    },
    "appId": "com.powerpal.app",
    "productName": "PowerPal",
    "asar": true,
    "files": [
      "dist/**/*",
      "main.cjs",
      "database/**/*.cjs",
      "scripts/**/*.cjs",
      "!src/**/*",
      "!*.map"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "portable"
    }
  }
}
